{
    "functions": [
        {
            "name": "multiSendBTC",
            "type": "Function",
            "payable": false,
            "onlyOwner": false,
            "inputs": [
                {
                    "name": "addressAndAmount",
                    "type": "ADDRESS_UINT256_TUPLE"
                }
            ],
            "outputs": [
                {
                    "name": "success",
                    "type": "BOOL"
                }
            ]
        },
        {
            "name": "withdrawFees",
            "type": "Function",
            "payable": false,
            "onlyOwner": false,
            "inputs": [
